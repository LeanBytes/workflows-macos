# ── Local Developer ID Direct build — environment ────────────────────────────
# Used by scripts/build-local.sh to run the SAME build CI runs, on your Mac.
#
#   cp examples/local-build.env.example ~/.config/workflows-macos/<app>.env
#   chmod 600 ~/.config/workflows-macos/<app>.env
#   # fill the values below, then:
#   /path/to/workflows-macos/scripts/build-local.sh --env-file ~/.config/workflows-macos/<app>.env
#
# ⚠️  This file contains a base64-encoded signing certificate and its password.
#     Store it OUTSIDE any git repository and keep it chmod 600. Do NOT commit it.
#     (If you keep it at <app-repo>/Config/local-build.env instead, add that path
#     AND `dist/` to the app repo's .gitignore.)
#
# The values are exactly your GitHub repo's Actions secrets + vars — copy them
# from there (Settings → Secrets and variables → Actions). build-local.sh sources
# this file with `set -a`, so plain KEY=value lines are fine (no `export` needed).

# ── App identity (GitHub Actions *vars*) ─────────────────────────────────────
SCHEME_NAME="FlowMoose"
BUNDLE_ID="com.example.flowmoose"
PRODUCT_NAME="FlowMoose"

# ── Project type ─────────────────────────────────────────────────────────────
USE_TUIST=true                 # FlowMoose uses Tuist; set false for plain SwiftPM
# CONFIGURATION="Release"      # default Release; set if your .xcodeproj differs

# ── Optional pre-build asset hook ────────────────────────────────────────────
# Runs before archive (cwd = the app repo). Leave unset if the asset is already
# present locally (e.g. FlowMoose's Whisper model).
# PRE_BUILD_SCRIPT=".ci/download-whisper-model.sh"

# ── Signing + notarization (GitHub Actions *secrets*) ────────────────────────
# Base64 values are the same strings stored in GitHub. On macOS, produce them
# with:  base64 -i path/to/file | pbcopy
DEVELOPER_ID_P12_BASE64="PASTE_BASE64_OF_DEVELOPER_ID_P12"
DEVELOPER_ID_PASSWORD="the p12 export password"
KEYCHAIN_PASSWORD="any throwaway password for the ephemeral keychain"
PROV_PROF_DEVID_BASE64="PASTE_BASE64_OF_MAIN_DEVELOPER_ID_PROVISIONPROFILE"
ASC_KEY_ID="XXXXXXXXXX"
ASC_ISSUER_ID="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
ASC_KEY_BASE64="PASTE_BASE64_OF_ASC_AuthKey_p8"

# ── Extensions (macpacker only — leave unset for FlowMoose/filefillet) ───────
# HAS_FINDER=true
# BUNDLE_ID_FINDER="com.example.app.finder"
# PROV_PROF_DEVID_FINDER_BASE64="PASTE_BASE64"
# HAS_QUICKLOOK=true
# BUNDLE_ID_QUICKLOOK="com.example.app.quicklook"
# PROV_PROF_DEVID_QL_BASE64="PASTE_BASE64"

# ── Escape hatch ─────────────────────────────────────────────────────────────
# EXTRA_ARGS="BUILD_RELEASE_DATE=2026-06-06"   # extra xcodebuild build settings
